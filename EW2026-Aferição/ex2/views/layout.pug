html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title EW2026 — Oficina AutoRepair
    style.
      body { font-family: Arial, sans-serif; margin: 0; background: #f4f4f4; color: #333; }
      header { background: #1a1a2e; color: white; padding: 16px 32px; }
      header h1 { margin: 0; font-size: 1.4rem; }
      header p { margin: 4px 0 0; font-size: 0.9rem; color: #aaa; }
      main { padding: 24px 32px; }
      table { width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 6px rgba(0,0,0,0.1); }
      th { background: #1a1a2e; color: white; padding: 12px 16px; text-align: left; }
      td { padding: 10px 16px; border-bottom: 1px solid #eee; }
      tr:last-child td { border-bottom: none; }
      tr:hover td { background: #f0f4ff; }
      a { color: #0066cc; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .back { display: inline-block; margin-bottom: 16px; padding: 8px 16px; background: #1a1a2e; color: white; border-radius: 4px; }
      .back:hover { background: #2a2a4e; text-decoration: none; }
      h2 { color: #1a1a2e; }
      .card { background: white; border-radius: 8px; padding: 24px; box-shadow: 0 2px 6px rgba(0,0,0,0.1); margin-bottom: 16px; }
      .field { margin-bottom: 10px; }
      .label { font-weight: bold; color: #555; min-width: 160px; display: inline-block; }
      ul { padding-left: 20px; }
      li { margin-bottom: 6px; }
  body
    header
      h1 🔧 Oficina AutoRepair
      p EW2026 — Gestão de Reparações de Automóveis
    main
      block content
