extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h2 Lista de Filmes
    .w3-container
      table.w3-table-all.w3-hoverable
        tr
          th Título
          th Ano
          th Atores
          th Géneros
        each f in filmes
          tr(onclick=`window.location='/filmes/${f._id}'` style="cursor:pointer")
            td= f.title
            td= f.year
            td= f.numAtores
            td= f.numGeneros