extends layout

block content
  .w3-card-4
    header.w3-container.w3-indigo
      h2 Lista de Exames Médicos Desportivos
      .w3-bar.w3-margin-bottom
        a.w3-button.w3-green.w3-round(href="/emd/registo") + Novo Registo
        a.w3-button.w3-teal.w3-round.w3-margin-left(href="/emd?sort=data") Ordenar Data (Decr)
        a.w3-button.w3-teal.w3-round.w3-margin-left(href="/emd?sort=nome") Ordenar Nome (Cresc)
        a.w3-button.w3-orange.w3-round.w3-margin-left(href="/emd/stats") Estatísticas
    
    .w3-container
      table.w3-table-all.w3-hoverable.w3-margin-top
        tr
          th Nome
          th Data
          th Modalidade
          th Resultado
          th Operações
        each e in list
          tr
            td(onclick=`window.location='/emd/${e._id}'` style="cursor:pointer") #{e.nome.primeiro} #{e.nome.último}
            td= e.dataEMD
            td= e.modalidade
            td= e.resultado ? 'Apto' : 'Não Apto'
            td
              a.w3-button.w3-blue.w3-small(href=`/emd/editar/${e._id}`) Editar
              a.w3-button.w3-red.w3-small.w3-margin-left(href=`/emd/apagar/${e._id}`) Apagar