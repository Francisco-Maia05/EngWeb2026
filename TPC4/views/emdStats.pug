extends layout

block content
  .w3-card-4
    header.w3-container.w3-indigo
      h2 Estatísticas de Exames
    
    .w3-container.w3-padding-16
      .w3-row-padding
        .w3-half
          h4 Distribuição por Sexo
          ul.w3-ul.w3-border
            li Masculino: #{list.filter(e => e.género == 'M').length}
            li Feminino: #{list.filter(e => e.género == 'F').length}
        
        .w3-half
          h4 Distribuição por Resultado
          ul.w3-ul.w3-border
            li Aptos: #{list.filter(e => e.resultado == true || e.resultado == "true").length}
            li Não Aptos: #{list.filter(e => e.resultado == false || e.resultado == "false").length}

    footer.w3-container.w3-indigo
      a.w3-button.w3-light-grey.w3-margin(href="/emd") Voltar