extends layout

block content
  .w3-card-4
    header.w3-container.w3-indigo
      h2= emd ? "Editar Exame Médico" : "Novo Exame Médico"
    
    form.w3-container.w3-padding-16(method="POST" action=emd ? `/emd/${emd._id}` : "/emd")
      fieldset.w3-margin-bottom
        legend Informação Pessoal
        label Primeiro Nome
        input.w3-input.w3-round(type="text" name="nome[primeiro]" value=emd ? emd.nome.primeiro : "" required)
        label Último Nome
        input.w3-input.w3-round(type="text" name="nome[último]" value=emd ? emd.nome.último : "" required)
        .w3-row
          .w3-half
            label Idade
            input.w3-input.w3-round(type="number" name="idade" value=emd ? emd.idade : "")
          .w3-half
            label Género
            select.w3-select(name="género")
                option(value="M" selected=(emd && emd.género=='M')) Masculino
                option(value="F" selected=(emd && emd.género=='F')) Feminino
      
      fieldset
        legend Detalhes do Exame
        label Data do Exame
        input.w3-input.w3-round(type="date" name="dataEMD" value=emd ? emd.dataEMD : "" required)
        label Modalidade
        input.w3-input.w3-round(type="text" name="modalidade" value=emd ? emd.modalidade : "" required)
        label Clube
        input.w3-input.w3-round(type="text" name="clube" value=emd ? emd.clube : "")
        
        label Resultado
        .w3-container
            input.w3-radio(type="radio" name="resultado" value="true" checked=(emd ? emd.resultado : true))
            label.w3-margin-right Apto
            input.w3-radio(type="radio" name="resultado" value="false" checked=(emd ? !emd.resultado : false))
            label Não Apto

      button.w3-btn.w3-green.w3-margin-top(type="submit")= emd ? "Atualizar" : "Inserir"
      a.w3-btn.w3-red.w3-margin-top.w3-margin-left(href="/emd") Cancelar