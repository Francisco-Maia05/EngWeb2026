extends layout

block content
  .w3-card-4
    header.w3-container.w3-indigo
      h2 Ficha de Exame Médico: #{emd._id}
    
    .w3-container.w3-padding-16
      ul.w3-ul.w3-card-2
        li #[b Nome:] #{emd.nome.primeiro} #{emd.nome.último}
        li #[b Data:] #{emd.dataEMD}
        li #[b Modalidade:] #{emd.modalidade}
        li #[b Idade:] #{emd.idade}
        li #[b Género:] #{emd.género}
        li #[b Morada:] #{emd.morada}
        li #[b Clube:] #{emd.clube}
        li #[b Email:] #{emd.email}
        li #[b Federado:] #{emd.federado ? 'Sim' : 'Não'}
        li #[b Resultado:] #{emd.resultado ? 'Apto' : 'Não Apto'}

    footer.w3-container.w3-indigo
      a.w3-button.w3-light-grey.w3-margin(href="/emd") Voltar