extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Cinema 2026
      nav.w3-bar.w3-border.w3-light-grey
        a.w3-bar-item.w3-button(href="/filmes") Filmes
        a.w3-bar-item.w3-button(href="/atores") Atores
        a.w3-bar-item.w3-button(href="/generos") Géneros
    .w3-container
      table.w3-table-all.w3-hoverable
        tr
          th Título
          th Ano
          th Géneros
          th Elenco
        each f in lista
          tr
            // Usamos o título como "id" para o link
            td: a(href="/filmes/" + f.title)= f.title
            td= f.year
            td= f.genres.length
            td= f.cast.length