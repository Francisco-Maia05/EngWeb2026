extends layout

block content
  .w3-card-4
    header.w3-container.w3-indigo
      h1 Lista de Atores
    .w3-container
      table.w3-table-all
        tr
          th Nome
          th Número de Filmes
        each a in lista
          tr
            td: a(href="/atores/"+a.nome)= a.nome
            td= a.nFilmes
    footer.w3-container.w3-indigo
      a.w3-button(href="/") Voltar