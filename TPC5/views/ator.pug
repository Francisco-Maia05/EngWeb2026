extends layout

block content
  .w3-card-4
    header.w3-container.w3-indigo
      h1 Filmes de #{nome}
    .w3-container
      ul.w3-ul.w3-hoverable
        each f in filmes
          li: a(href="/filmes/"+f.id)= f.title
    footer.w3-container.w3-indigo
      a.w3-button(href="/atores") Voltar